// =========================================================
//  UTILIDADES BÁSICAS
// =========================================================
static int sysrun(const std::string& cmd) {
    int r = ::system(cmd.c_str());
    if (r == -1) return 1;
    return WIFEXITED(r) ? WEXITSTATUS(r) : 1;
}

static std::string runCapture(const std::string& cmd) {
    FILE* pipe = popen((cmd + " 2>/dev/null").c_str(), "r");
    if (!pipe) return "";
    std::string out;
    char buf[512];
    while (fgets(buf, sizeof(buf), pipe)) out += buf;
    pclose(pipe);
    while (!out.empty() && (out.back() == '\n' || out.back() == '\r' || out.back() == ' '))
        out.pop_back();
    return out;
}

// =========================================================
//  UI PRIMITIVAS (con sn_lines)
// =========================================================
inline void hr()   { sn_print_linea(); }
inline void sep()  { sn_print_sep(); }
inline void sep3() { std::cout << R << "- - - - - - - - - - - - - - - - - - - - - - - - - - - - -" << N << "\n"; }

inline void clearScreen() {
    std::cout << "\033[2J\033[3J\033[1;1H" << std::flush;
}
inline void hideCursor()  { std::cout << "\033[?25l" << std::flush; }
inline void showCursor()  { std::cout << "\033[?25h" << std::flush; }

inline void pauseUi() {
    std::cout << "\n" << Y << "            ►► Presiona ENTER para continuar ◄◄" << N << "\n";
    std::string dummy;
    std::getline(std::cin, dummy);
}

static void showTitle(const std::string& text, bool /*unused*/ = false) {
    clearScreen();
    hr();
    int pad = (54 - static_cast<int>(text.size())) / 2;
    if (pad < 0) pad = 0;
    std::cout << W << BOLD << std::string(static_cast<size_t>(pad), ' ') << text << N << "\n";
    hr();
}

static void printCenter(const std::string& color, const std::string& text) {
    int pad = (54 - static_cast<int>(text.size())) / 2;
    if (pad < 0) pad = 0;
    std::cout << color << std::string(static_cast<size_t>(pad), ' ') << text << N << "\n";
}

// Margen izquierdo de 4 espacios como exige la regla
static void printItem(const std::string& num, const std::string& label) {
    std::cout << "    " << R << "[" << Y << num << R << "]"
              << N   << "  " << C << label << N << "\n";
}

static std::string menuPrompt() {
    std::cout << "\n" << W << "┌─[" << G << BOLD << "Seleccione una opción" << W << "]" << N << "\n";
    std::cout << "╰─> : " << G;
    std::string op;
    if (!std::getline(std::cin, op)) op.clear();
    std::cout << N;
    return op;
}

static std::string fieldPrompt(const std::string& label, const std::string& def = "") {
    std::cout << "\n" << W << "┌─[" << G << BOLD << label;
    if (!def.empty()) std::cout << W << " — default: " << Y << def;
    std::cout << W << "]" << N << "\n";
    std::cout << "╰─> : " << G;
    std::string v;
    if (!std::getline(std::cin, v)) v.clear();
    std::cout << N;
    if (v.empty() && !def.empty()) return def;
    return v;
}

// =========================================================
//  SPINNER / FORK (con execl y redirección silenciosa)
// =========================================================
static int spinnerWait(pid_t pid, const std::string& msg) {
    const char* fr[] = {"⠋","⠙","⠹","⠸","⠼","⠴","⠦","⠧","⠇","⠏"};
    int idx = 0, status = 0;
    hideCursor();
    while (true) {
        pid_t ret = waitpid(pid, &status, WNOHANG);
        if (ret < 0 && errno != EINTR) break;
        if (ret > 0) break;
        std::cout << "\r    " << C << fr[idx] << N << " " << W << msg << N;
        std::cout.flush();
        idx = (idx + 1) % 10;
        std::this_thread::sleep_for(std::chrono::milliseconds(100));
    }
    int ec = WIFEXITED(status) ? WEXITSTATUS(status) : 1;
    const char* ico = (ec == 0) ? G : R;
    const char* chk = (ec == 0) ? "✓" : "✗";
    std::cout << "\r    " << ico << chk << N << " " << W
              << std::left << std::setw(50) << msg << N << "\n";
    showCursor();
    return ec;
}

static int forkCmd(const std::string& shellCmd, const std::string& msg) {
    pid_t pid = fork();
    if (pid < 0) {
        std::cerr << R << "fork() falló: " << strerror(errno) << N << "\n";
        return 1;
    }
    if (pid == 0) {
        int dn = open("/dev/null", O_WRONLY);
        if (dn >= 0) { dup2(dn, STDOUT_FILENO); dup2(dn, STDERR_FILENO); close(dn); }
        ::system(shellCmd.c_str());
        std::exit(0);
    }
    return spinnerWait(pid, msg);
}

